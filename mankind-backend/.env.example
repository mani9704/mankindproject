# Database Configuration
DB_HOST=your-db-host
DB_PORT=26996
DB_NAME=mankind_matrix_db
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# Database Connection Properties
DB_CONNECT_TIMEOUT=30000
DB_SOCKET_TIMEOUT=30000
DB_USE_SSL=true
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true
DB_SERVER_TIMEZONE=UTC
DB_AUTO_RECONNECT=true
DB_FAIL_OVER_READ_ONLY=false

# Hikari Connection Pool Settings
DB_HIKARI_MAX_POOL_SIZE=2
DB_HIKARI_MIN_IDLE=0
DB_HIKARI_CONNECTION_TIMEOUT=20000
DB_HIKARI_IDLE_TIMEOUT=120000
DB_HIKARI_MAX_LIFETIME=300000
DB_HIKARI_LEAK_DETECTION_THRESHOLD=30000

# Keycloak Database Settings (Separate pool)
KEYCLOAK_DB_HIKARI_MAX_POOL_SIZE=5
KEYCLOAK_DB_HIKARI_MIN_IDLE=1
KEYCLOAK_DB_HIKARI_CONNECTION_TIMEOUT=30000
KEYCLOAK_DB_HIKARI_IDLE_TIMEOUT=180000
KEYCLOAK_DB_HIKARI_MAX_LIFETIME=600000

# Stripe Configuration
STRIPE_SECRET_KEY=your-stripe-secret-key

# Notification Service Configuration
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Keycloak Settings
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
KEYCLOAK_HTTP_PORT=8180
KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_HOSTNAME_STRICT_HTTPS=false
KEYCLOAK_URL=http://localhost:8180

# Service URLs (for inter-service communication)
USER_SERVICE_URL=http://localhost:8081
PRODUCT_SERVICE_URL=http://localhost:8080
CART_SERVICE_URL=http://localhost:8082
WISHLIST_SERVICE_URL=http://localhost:8083
PAYMENT_SERVICE_URL=http://localhost:8084
NOTIFICATION_SERVICE_URL=http://localhost:8086
GATEWAY_SERVICE_URL=http://localhost:8085
COUPON_SERVICE_URL=http://localhost:8087
